# ============================================================
# BLOCK 5 — PIPELINE LOGGER AND S3 UPLOAD HELPERS
# ============================================================
# PIPELINE_LOG_LINES: a Python list that collects every log message during
#   the run. Think of it as a notepad accumulating entries as the job runs.
#
# log(): every time something important happens we call log("message").
#   It does TWO things simultaneously:
#     print(line)                     → goes to CloudWatch in real time
#     PIPELINE_LOG_LINES.append(line) → saved for writing to S3 at the end
#   This dual approach gives live visibility during the run AND a permanent
#   record in S3 after completion.
#
# upload_json(): writes a Python dictionary to S3 as a formatted JSON file.
#   json.dumps(payload, indent=2) converts the dict to a human-readable string.
#   .encode("utf-8") converts that string to bytes (S3 stores bytes not strings).
#
# upload_text(): same idea but for plain text (used for the pipeline log file).
#
# ⚠ IMPROVEMENT (Python 3.12 deprecation):
#   datetime.utcnow() is deprecated. It returns a "naive" datetime — no
#   timezone information is attached even though it conceptually represents UTC.
#   This can cause silent timezone conversion errors when other systems consume
#   these timestamps.
#   FIX: replace all datetime.utcnow() with datetime.now(timezone.utc)
#   and add timezone to the import:
#       from datetime import datetime, timezone
#   The output changes from:
#       "2026-03-17T14:30:00.123456"         (no timezone — ambiguous)
#   to:
#       "2026-03-17T14:30:00.123456+00:00"   (explicit UTC — unambiguous)
# ============================================================
PIPELINE_LOG_LINES = []


def log(message: str) -> None:
    # ⚠ datetime.utcnow() deprecated in Python 3.12
    # FIX: use datetime.now(timezone.utc).isoformat()
    line = f"{datetime.utcnow().isoformat()} INFO {message}"
    PIPELINE_LOG_LINES.append(line)
    print(line)  # → CloudWatch (real-time)


def upload_json(key: str, payload: dict) -> None:
    s3.put_object(
        Bucket=BUCKET,
        Key=key,
        Body=json.dumps(payload, indent=2).encode("utf-8"),
        ContentType="application/json"
    )


def upload_text(key: str, text: str) -> None:
    s3.put_object(
        Bucket=BUCKET,
        Key=key,
        Body=text.encode("utf-8"),
        ContentType="text/plain"
    )


